# Backend .gitignore (Node/Express style)
# Clean, production-ready ignore for server-side code

# -------- Dependencies --------
node_modules/
.pnp/
.pnp.js

# -------- Environment / secrets --------
.env
.env.*
!.env.example

# -------- Build / compiled output --------
/build/
dist/
/lib/
/out/
/coverage/

# -------- Logs & debugging --------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.local

# -------- Cache --------
.cache/
.nyc_output/
*.cache

# -------- Process files --------
*.pid
*.seed

# -------- System files --------
.DS_Store
Thumbs.db
desktop.ini

# -------- IDE / editor --------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# -------- Temporary / backup --------
*.tmp
*.temp
*.bak
*.backup
*.orig
*~
~*

# -------- Test coverage --------
coverage/
coverage-final.json

# -------- Misc / generated --------
.env.local
.env.development.local
.env.test.local
.env.production.local

# -------- Optional package manager caches --------
# .yarn/*
# .yarnrc.yml
# .pnpm-store/

# End of file
